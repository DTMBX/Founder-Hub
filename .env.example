# ============================================================================
# XTX396 SITE CONFIGURATION
# Copy this file to .env and customize for your site
# ============================================================================

# ─── SITE IDENTITY ──────────────────────────────────────────────────────────
VITE_SITE_ID=my-site
VITE_SITE_NAME=My Business
VITE_SITE_TAGLINE=Professional Services You Can Trust
VITE_SITE_DOMAIN=mybusiness.com

# ─── BUSINESS DETAILS ───────────────────────────────────────────────────────
VITE_BUSINESS_LEGAL_NAME=My Business LLC
VITE_BUSINESS_PHONE=(555) 123-4567
VITE_BUSINESS_EMAIL=contact@mybusiness.com
VITE_ADDRESS_STREET=123 Main Street
VITE_ADDRESS_CITY=Anytown
VITE_ADDRESS_STATE=TX
VITE_ADDRESS_ZIP=12345
VITE_BUSINESS_HOURS=Mon-Fri 9am-5pm

# ─── SOCIAL LINKS ───────────────────────────────────────────────────────────
VITE_SOCIAL_FACEBOOK=https://facebook.com/mybusiness
VITE_SOCIAL_TWITTER=
VITE_SOCIAL_INSTAGRAM=https://instagram.com/mybusiness
VITE_SOCIAL_LINKEDIN=
VITE_SOCIAL_YOUTUBE=

# ─── AUTHENTICATION (Supabase — REQUIRED) ───────────────────────────────────
# Supabase is required for production. Get these from your Supabase project.
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ─── EVIDENT INTEGRATION ────────────────────────────────────────────────────
# Connect to Evident evidence engine (read-only dashboards, deep links)
VITE_EVIDENT_ENABLED=false
VITE_EVIDENT_API_URL=https://evident.yourdomain.com

# ─── SEO CONFIGURATION ──────────────────────────────────────────────────────
VITE_SEO_TITLE=My Business | Professional Services
VITE_SEO_DESCRIPTION=Trusted professional services for your business needs.
VITE_SEO_KEYWORDS=professional services,business,local
VITE_OG_IMAGE=/og/default.png
VITE_SCHEMA_TYPE=LocalBusiness
VITE_SCHEMA_PRICE_RANGE=$$

# ─── THEME & STYLING ────────────────────────────────────────────────────────
# Presets: default, law-firm, medical, contractor, nonprofit, ecommerce
VITE_THEME_PRESET=default

# Custom colors (override preset)
VITE_COLOR_PRIMARY=#3182ce
VITE_COLOR_SECONDARY=#4a5568
VITE_COLOR_ACCENT=#38a169
VITE_COLOR_BACKGROUND=#0a0a0a
VITE_COLOR_FOREGROUND=#fafafa

# Effects
VITE_EFFECT_GLASS=true
VITE_EFFECT_ANIMATIONS=true
VITE_EFFECT_PARTICLES=false
VITE_EFFECT_GRADIENTS=true
VITE_EFFECT_SHADOWS=true

# Layout (set to true for edge-to-edge design)
VITE_LAYOUT_NO_WHITESPACE=false
VITE_LAYOUT_MAX_WIDTH=1400px
VITE_LAYOUT_PADDING=1.5rem
VITE_LAYOUT_SECTION_SPACING=6rem

# ─── CONTACT FORM ───────────────────────────────────────────────────────────
VITE_CONTACT_ENDPOINT=/api/contact
VITE_CONTACT_EMAIL_TO=contact@mybusiness.com
VITE_CONTACT_SUCCESS=Thank you! We'll be in touch within 24 hours.
VITE_LEAD_CATEGORIES=General Inquiry,Service Request,Support,Other

# Optional: Custom fields as JSON (advanced)
# VITE_CONTACT_FIELDS=[{"name":"name","label":"Full Name","type":"text","required":true}]

# reCAPTCHA (optional spam protection)
VITE_RECAPTCHA_ENABLED=false
VITE_RECAPTCHA_SITE_KEY=

# ─── E-COMMERCE / STRIPE ────────────────────────────────────────────────────
VITE_ENABLE_ECOMMERCE=false
VITE_STRIPE_ENABLED=false
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_CURRENCY=usd
VITE_STRIPE_COUNTRIES=US
VITE_STRIPE_SUCCESS_URL=/checkout/success
VITE_STRIPE_CANCEL_URL=/checkout/cancel
VITE_STRIPE_AUTO_TAX=false

# Products from Stripe catalog (recommended for inventory management)
VITE_PRODUCTS_FROM_STRIPE=false
VITE_PRODUCTS_SHOW_PRICES=true
VITE_PRODUCTS_SHOW_STOCK=false
VITE_PRODUCTS_COLUMNS=3

# Inline products (for simple sites - JSON array)
# VITE_PRODUCTS=[{"id":"prod_1","stripePriceId":"price_xxx","name":"Product","price":2999}]

# ─── FEATURE FLAGS ──────────────────────────────────────────────────────────
VITE_ENABLE_BILLING=false
VITE_ENABLE_LEADS=true
VITE_ENABLE_BLOG=false
VITE_ENABLE_GALLERY=false
VITE_ENABLE_TESTIMONIALS=true
VITE_ENABLE_FAQ=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CHAT=false
VITE_ENABLE_NEWSLETTER=false
VITE_ENABLE_ADMIN=true
VITE_ENABLE_AUDIT=true

# ─── ANALYTICS ──────────────────────────────────────────────────────────────
VITE_GA_ID=
VITE_FB_PIXEL_ID=
VITE_TRACK_FORMS=true
VITE_TRACK_CLICKS=false
VITE_TRACK_SCROLL=false
