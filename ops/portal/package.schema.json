{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HandoffPackageManifest",
  "description": "Schema for a client handoff package manifest, used to verify package integrity and completeness.",
  "type": "object",
  "required": [
    "packageId",
    "clientId",
    "engagementId",
    "files",
    "totalSize",
    "fileCount",
    "manifestHash",
    "createdAt"
  ],
  "properties": {
    "packageId": {
      "type": "string",
      "pattern": "^PKG-[a-z0-9]+-[a-z0-9]+$",
      "description": "Unique package identifier"
    },
    "clientId": {
      "type": "string",
      "minLength": 1,
      "description": "Client identifier"
    },
    "engagementId": {
      "type": "string",
      "minLength": 1,
      "description": "Engagement or matter identifier"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative file path within the package"
          },
          "size": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 hash of the file content"
          }
        },
        "additionalProperties": false
      },
      "description": "List of files included in the package"
    },
    "totalSize": {
      "type": "integer",
      "minimum": 0,
      "description": "Sum of all file sizes in bytes"
    },
    "fileCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of files in the package"
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash over the package ID and file list for integrity verification"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 package creation timestamp"
    }
  },
  "additionalProperties": false
}
