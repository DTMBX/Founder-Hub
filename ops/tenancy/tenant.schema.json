{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenant",
  "description": "Schema for a tenant in the multi-tenant isolation layer (B16-P1)",
  "type": "object",
  "required": [
    "tenantId",
    "name",
    "tier",
    "status",
    "createdAt",
    "allowedTools",
    "featureFlags",
    "rateLimitProfile"
  ],
  "properties": {
    "tenantId": {
      "type": "string",
      "description": "UUID or reserved identifier (e.g., public-demo)"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "tier": {
      "type": "string",
      "enum": ["public", "pro", "internal"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "suspended"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "allowedTools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "featureFlags": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "rateLimitProfile": {
      "type": "object",
      "required": [
        "requestsPerMinute",
        "maxRows",
        "maxExportBytes",
        "maxConcurrentSessions"
      ],
      "properties": {
        "requestsPerMinute": { "type": "integer", "minimum": 1 },
        "maxRows": { "type": "integer", "minimum": 1 },
        "maxExportBytes": { "type": "integer", "minimum": 1 },
        "maxConcurrentSessions": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
