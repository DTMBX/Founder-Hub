      "working_dir_policy": { "type": "fixed", "value": "." },
      "env_allowlist": [],
      "command_template": {
        "executable": "git",
        "args": ["rev-parse", "--abbrev-ref", "HEAD"]
      },
      "expected_outputs": ["text"],
      "timeout_seconds": 10,
      "side_effects": "read_only"
    },
