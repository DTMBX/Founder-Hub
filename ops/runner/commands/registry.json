        "required": ["ruleId"],
        "additionalProperties": false
      },
      "working_dir_policy": { "type": "fixed", "value": "." },
      "env_allowlist": [],
      "command_template": {
        "executable": "__internal__",
        "args": ["automation_dry_run", "{{ruleId}}"]
      },
      "expected_outputs": ["json"],
      "timeout_seconds": 30,
      "side_effects": "read_only"
    },
