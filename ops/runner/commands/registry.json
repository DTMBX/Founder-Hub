    {
      "id": "repo.search",
      "description": "Search for a pattern in tracked files (git grep, bounded output).",
      "roles_allowed": ["Admin", "Operator"],
      "safe_mode_behavior": {
        "allowed": true,
        "reason": "Read-only code search, no modifications."
      },
      "args_schema": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "minLength": 2,
            "description": "The search pattern (literal string or basic regex)."
          }
        },
        "required": ["pattern"],
        "additionalProperties": false
      },
      "working_dir_policy": { "type": "fixed", "value": "." },
      "env_allowlist": [],
      "command_template": {
        "executable": "git",
        "args": ["grep", "-n", "--count", "{{pattern}}"]
      },
      "expected_outputs": ["text"],
      "timeout_seconds": 30,
      "side_effects": "read_only",
      "output_limits": { "max_chars": 16384, "max_lines": 500 }
    }
