{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Copilot Intent Schema",
  "description": "Defines the structure for a copilot user intent and the resulting execution plan.",
  "definitions": {
    "Intent": {
      "type": "object",
      "required": ["user_message", "role", "safe_mode", "session_id"],
      "properties": {
        "user_message": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "role": { "enum": ["Admin", "Operator", "ReadOnly"] },
        "safe_mode": { "type": "boolean" },
        "session_id": { "type": "string", "minLength": 1 },
        "conversation_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "content"],
            "properties": {
              "role": { "enum": ["user", "assistant", "system"] },
              "content": { "type": "string" }
            }
          },
          "maxItems": 50
        }
      }
    },
    "ProposedCommand": {
      "type": "object",
      "required": ["command_id", "args"],
      "properties": {
        "command_id": { "type": "string" },
        "args": { "type": "object" }
      }
    },
    "Plan": {
      "type": "object",
      "required": ["summary", "proposed_commands", "risk_flags", "requires_confirmation", "reason"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "proposed_commands": {
          "type": "array",
          "items": { "$ref": "#/definitions/ProposedCommand" }
        },
        "risk_flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requires_confirmation": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    }
  }
}
