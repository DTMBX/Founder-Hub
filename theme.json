{
  "name": "Founder Hub",
  "description": "Devon Tyler — Founder Hub operational command center theme",
  "style": "new-york",
  "baseColor": "neutral",
  "cssVariables": true,
  "colorSystem": "oklch",
  "radius": "0.625rem",
  "darkMode": {
    "strategy": "class",
    "default": "dark",
    "storageKey": "founder-hub-theme"
  },
  "palette": {
    "light": {
      "background": "oklch(1 0 0)",
      "foreground": "oklch(0.145 0 0)",
      "primary": "oklch(0.205 0 0)",
      "primary-foreground": "oklch(0.985 0 0)",
      "accent": "oklch(0.97 0 0)",
      "destructive": "oklch(0.577 0.245 27.325)"
    },
    "dark": {
      "background": "oklch(0.11 0.01 55)",
      "foreground": "oklch(0.95 0.02 85)",
      "primary": "oklch(0.65 0.17 155)",
      "primary-foreground": "oklch(0.12 0.02 155)",
      "accent": "oklch(0.58 0.20 300)",
      "destructive": "oklch(0.62 0.20 25)"
    }
  },
  "fonts": {
    "sans": "Inter, system-ui, sans-serif",
    "mono": "JetBrains Mono, monospace"
  }
}