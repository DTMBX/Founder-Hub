{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evident.tech/schemas/publish-target.schema.json",
  "title": "PublishTarget",
  "description": "Schema for publish target registration and validation.",
  "type": "object",
  "required": ["id", "name", "kind", "enabled", "safe_mode_allowed", "required_capabilities"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,48}[a-z0-9]$",
      "description": "Unique target identifier."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Human-readable target name."
    },
    "kind": {
      "type": "string",
      "enum": ["hosted", "zip", "github_pr"],
      "description": "Publish target kind."
    },
    "enabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether this target is currently enabled."
    },
    "safe_mode_allowed": {
      "type": "boolean",
      "description": "Whether this target is available when Safe Mode is ON."
    },
    "required_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "description": "RBAC capabilities required to use this target."
    },
    "blocked_tenant_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["public-demo", "trial", "suspended"]
      },
      "default": [],
      "description": "Tenant types that cannot use this target."
    },
    "config": {
      "type": "object",
      "description": "Target-specific configuration (non-secret).",
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["log_publish", "append_only"],
      "properties": {
        "log_publish": {
          "type": "boolean",
          "const": true
        },
        "append_only": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    }
  }
}
