{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "B12 Command Registry Schema",
  "description": "Validates the structure of the Command Registry SSOT. Every command must declare its security posture, argument schema, and execution constraints.",
  "type": "object",
  "required": ["version", "commands"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the registry."
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/definitions/CommandEntry" },
      "minItems": 1
    }
  },
  "definitions": {
    "CommandEntry": {
      "type": "object",
      "required": [
        "id",
        "description",
        "roles_allowed",
        "safe_mode_behavior",
        "args_schema",
        "working_dir_policy",
        "env_allowlist",
        "command_template",
        "expected_outputs",
        "timeout_seconds",
        "side_effects"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$",
          "description": "Stable dotted identifier (e.g. repo.status)."
        },
        "description": {
          "type": "string",
          "minLength": 5,
          "maxLength": 200
        },
        "roles_allowed": {
          "type": "array",
          "items": { "enum": ["Admin", "Operator", "ReadOnly"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "safe_mode_behavior": {
          "type": "object",
          "required": ["allowed", "reason"],
          "additionalProperties": false,
          "properties": {
            "allowed": { "type": "boolean" },
            "reason": { "type": "string", "minLength": 3 }
          }
        },
        "args_schema": {
          "type": "object",
          "description": "JSON Schema for command arguments. Use { \"type\": \"object\", \"properties\": {} } for zero-arg commands."
        },
        "working_dir_policy": {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "enum": ["fixed", "allowlisted"] },
            "value": {
              "type": ["string", "array"],
              "description": "Fixed path or array of allowed paths."
            }
          }
        },
        "env_allowlist": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
          "uniqueItems": true,
          "description": "Environment variable names (no values) the command may read."
        },
        "command_template": {
          "type": "object",
          "required": ["executable", "args"],
          "additionalProperties": false,
          "properties": {
            "executable": { "type": "string", "minLength": 1 },
            "args": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tokenized arguments. Use {{argName}} for template substitution from validated args."
            }
          }
        },
        "expected_outputs": {
          "type": "array",
          "items": { "enum": ["json", "text", "artifact_path"] },
          "minItems": 1
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "side_effects": {
          "enum": ["none", "read_only", "writes_repo", "deploys", "network_egress"]
        },
        "output_limits": {
          "type": "object",
          "properties": {
            "max_chars": { "type": "integer", "minimum": 1 },
            "max_lines": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "path_allowlist": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed paths for commands that read files. Relative to working dir."
        }
      }
    }
  }
}
