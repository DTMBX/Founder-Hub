{
  "$schema": "./Blueprint.schema.json",
  "id": "law-firm",
  "name": "Law Firm",
  "version": "2.0.0",
  "business_type": "lawfirm_general",
  "site_type": "law-firm",
  "audience": "Attorneys and law firms seeking a professional web presence that conveys trust, competence, and accessibility to prospective clients.",

  "required_pages": [
    { "slug": "home", "title": "Home", "template": "law-firm-home", "required_sections": ["hero", "practice-areas", "trust-badges", "testimonials", "cta"] },
    { "slug": "about", "title": "About the Firm", "template": "law-firm-about", "required_sections": ["about-intro", "attorneys", "timeline"] },
    { "slug": "practice-areas", "title": "Practice Areas", "template": "law-firm-practice", "required_sections": ["practice-list", "case-results"] },
    { "slug": "case-results", "title": "Case Results", "template": "law-firm-cases", "required_sections": ["case-grid", "case-downloads"] },
    { "slug": "team", "title": "Our Team", "template": "law-firm-team", "required_sections": ["attorneys-full"] },
    { "slug": "contact", "title": "Contact", "template": "law-firm-contact", "required_sections": ["contact-form", "office-location"] },
    { "slug": "faq", "title": "FAQ", "template": "law-firm-faq", "required_sections": ["faq-section"] }
  ],

  "required_sections": [
    { "id": "hero", "label": "Hero", "component": "hero-banner", "order": 0, "required": true },
    { "id": "practice-areas", "label": "Practice Areas", "component": "card-grid", "order": 1, "required": true },
    { "id": "trust-badges", "label": "Trust Badges", "component": "trust-badge-row", "order": 2, "required": true },
    { "id": "testimonials", "label": "Client Testimonials", "component": "testimonial-carousel", "order": 3, "required": true },
    { "id": "cta", "label": "Free Consultation", "component": "cta-block", "order": 4, "required": true },
    { "id": "about-intro", "label": "About Introduction", "component": "text-block", "order": 0, "required": true },
    { "id": "attorneys", "label": "Attorney Profiles", "component": "team-grid", "order": 1, "required": true },
    { "id": "timeline", "label": "Firm History", "component": "process-timeline", "order": 2, "required": true },
    { "id": "practice-list", "label": "Practice Area List", "component": "service-list", "order": 0, "required": true },
    { "id": "case-results", "label": "Notable Case Results", "component": "case-results-table", "order": 1, "required": true },
    { "id": "case-grid", "label": "Case Studies Grid", "component": "project-showcase", "order": 0, "required": true },
    { "id": "case-downloads", "label": "Case Documents", "component": "card-grid", "order": 1, "required": true },
    { "id": "attorneys-full", "label": "Full Team", "component": "team-grid", "order": 0, "required": true },
    { "id": "contact-form", "label": "Contact Form", "component": "contact-form", "order": 0, "required": true },
    { "id": "office-location", "label": "Office Location", "component": "map-embed", "order": 1, "required": true },
    { "id": "faq-section", "label": "Frequently Asked Questions", "component": "faq-accordion", "order": 0, "required": true }
  ],

  "required_components": [
    "hero-banner",
    "site-header",
    "nav-bar",
    "site-footer",
    "cta-block",
    "contact-form",
    "faq-accordion",
    "testimonial-carousel",
    "trust-badge-row",
    "card-grid",
    "text-block",
    "team-grid",
    "service-list",
    "case-results-table",
    "project-showcase",
    "process-timeline",
    "map-embed"
  ],

  "optional_components": [
    "blog-feed",
    "video-hero",
    "chat-widget",
    "intake-form",
    "social-proof-bar",
    "stats-counter",
    "logo-bar"
  ],

  "style_presets": [
    "lawfirm-classic",
    "lawfirm-modern",
    "lawfirm-bold",
    "lawfirm-elegant",
    "lawfirm-navy"
  ],

  "compliance_blocks": [
    {
      "id": "legal-disclaimer",
      "label": "Attorney Advertising Disclaimer",
      "type": "disclaimer",
      "required": true,
      "default_text": "Attorney Advertising. This website is designed for general information only. The information presented at this site should not be construed to be formal legal advice nor the formation of a lawyer/client relationship."
    },
    {
      "id": "privacy-policy",
      "label": "Privacy Policy",
      "type": "privacy",
      "required": true,
      "default_text": "We respect your privacy. Information collected through this website is handled in accordance with our privacy policy."
    },
    {
      "id": "terms-of-use",
      "label": "Terms of Use",
      "type": "terms",
      "required": true,
      "default_text": "Use of this website is subject to our terms of use. This site does not create an attorney-client relationship."
    },
    {
      "id": "accessibility-statement",
      "label": "Accessibility Statement",
      "type": "accessibility",
      "required": true,
      "default_text": "We are committed to ensuring that our website is accessible to everyone. If you have difficulty accessing any content, please contact us."
    }
  ],

  "content_requirements": {
    "min_pages": 5,
    "min_sections": 12,
    "min_words_per_page": 100,
    "require_contact_info": true,
    "require_business_name": true,
    "require_address": true,
    "require_hours": false
  },

  "demo_watermark_profile": {
    "enabled": true,
    "text": "PREVIEW — NOT A LIVE SITE",
    "opacity": 0.15,
    "position": "diagonal"
  },

  "seo_profile": {
    "title_pattern": "{{businessName}} — {{practiceArea}} Attorneys | {{city}}, {{state}}",
    "description_pattern": "{{businessName}} provides experienced {{practiceArea}} legal representation in {{city}}, {{state}}. Contact us for a consultation.",
    "schema_type": "LegalService",
    "og_image_pattern": "{{businessName}} — Trusted Legal Counsel",
    "keywords": ["attorney", "lawyer", "legal services", "law firm", "consultation"]
  },

  "feature_flags": {
    "enable_intake_form": true,
    "enable_chat_widget": false,
    "enable_blog": false,
    "enable_case_results": true,
    "enable_video_hero": false,
    "safe_mode": true
  }
}
