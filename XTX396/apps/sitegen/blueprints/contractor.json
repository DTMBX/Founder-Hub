{
  "$schema": "./Blueprint.schema.json",
  "id": "contractor",
  "name": "General Contractor",
  "version": "2.0.0",
  "business_type": "contractor_general",
  "site_type": "contractor",
  "audience": "General contractors seeking to showcase completed projects, build trust with homeowners, and generate qualified leads.",

  "required_pages": [
    { "slug": "home", "title": "Home", "template": "contractor-home", "required_sections": ["hero", "services", "trust-badges", "testimonials", "cta"] },
    { "slug": "services", "title": "Services", "template": "contractor-services", "required_sections": ["service-list", "process"] },
    { "slug": "projects", "title": "Projects", "template": "contractor-projects", "required_sections": ["project-showcase", "before-after", "gallery"] },
    { "slug": "about", "title": "About", "template": "contractor-about", "required_sections": ["about-intro", "team", "badges"] },
    { "slug": "contact", "title": "Contact", "template": "contractor-contact", "required_sections": ["estimate-form", "location", "hours"] },
    { "slug": "faq", "title": "FAQ", "template": "contractor-faq", "required_sections": ["faq-section"] }
  ],

  "required_sections": [
    { "id": "hero", "label": "Hero", "component": "hero-banner", "order": 0, "required": true },
    { "id": "services", "label": "Services Overview", "component": "card-grid", "order": 1, "required": true },
    { "id": "trust-badges", "label": "License & Insurance Badges", "component": "trust-badge-row", "order": 2, "required": true },
    { "id": "testimonials", "label": "Client Testimonials", "component": "testimonial-carousel", "order": 3, "required": true },
    { "id": "cta", "label": "Get a Free Estimate", "component": "cta-block", "order": 4, "required": true },
    { "id": "service-list", "label": "Service Details", "component": "service-list", "order": 0, "required": true },
    { "id": "process", "label": "Our Process", "component": "process-timeline", "order": 1, "required": true },
    { "id": "project-showcase", "label": "Featured Projects", "component": "project-showcase", "order": 0, "required": true },
    { "id": "before-after", "label": "Before & After", "component": "before-after-slider", "order": 1, "required": true },
    { "id": "gallery", "label": "Project Gallery", "component": "image-gallery", "order": 2, "required": true },
    { "id": "about-intro", "label": "About Your Company", "component": "text-block", "order": 0, "required": true },
    { "id": "team", "label": "Our Team", "component": "team-grid", "order": 1, "required": true },
    { "id": "badges", "label": "Certifications", "component": "badge-grid", "order": 2, "required": true },
    { "id": "estimate-form", "label": "Estimate Request", "component": "contact-form", "order": 0, "required": true },
    { "id": "location", "label": "Service Area", "component": "map-embed", "order": 1, "required": true },
    { "id": "hours", "label": "Business Hours", "component": "hours-widget", "order": 2, "required": true },
    { "id": "faq-section", "label": "Frequently Asked Questions", "component": "faq-accordion", "order": 0, "required": true }
  ],

  "required_components": [
    "hero-banner",
    "site-header",
    "nav-bar",
    "site-footer",
    "cta-block",
    "contact-form",
    "faq-accordion",
    "testimonial-carousel",
    "trust-badge-row",
    "card-grid",
    "service-list",
    "text-block",
    "team-grid",
    "project-showcase",
    "map-embed"
  ],

  "optional_components": [
    "before-after-slider",
    "image-gallery",
    "badge-grid",
    "process-timeline",
    "hours-widget",
    "estimate-form",
    "social-proof-bar",
    "stats-counter",
    "blog-feed"
  ],

  "style_presets": [
    "contractor-industrial",
    "contractor-clean",
    "contractor-bold",
    "contractor-warm",
    "contractor-slate"
  ],

  "compliance_blocks": [
    {
      "id": "licensing-disclosure",
      "label": "Licensing Disclosure",
      "type": "disclaimer",
      "required": true,
      "default_text": "Licensed and insured contractor. License number and insurance documentation available upon request."
    },
    {
      "id": "privacy-policy",
      "label": "Privacy Policy",
      "type": "privacy",
      "required": true,
      "default_text": "We respect your privacy. Information collected through this website is handled in accordance with our privacy policy."
    },
    {
      "id": "terms-of-service",
      "label": "Terms of Service",
      "type": "terms",
      "required": true,
      "default_text": "Use of this website is subject to our terms of service. Estimates provided via this site are preliminary and subject to on-site evaluation."
    },
    {
      "id": "accessibility-statement",
      "label": "Accessibility Statement",
      "type": "accessibility",
      "required": true,
      "default_text": "We are committed to ensuring that our website is accessible to everyone. If you have difficulty accessing any content, please contact us."
    }
  ],

  "content_requirements": {
    "min_pages": 5,
    "min_sections": 12,
    "min_words_per_page": 100,
    "require_contact_info": true,
    "require_business_name": true,
    "require_address": true,
    "require_hours": true
  },

  "demo_watermark_profile": {
    "enabled": true,
    "text": "PREVIEW — NOT A LIVE SITE",
    "opacity": 0.15,
    "position": "diagonal"
  },

  "seo_profile": {
    "title_pattern": "{{businessName}} — {{serviceType}} Contractor | {{city}}, {{state}}",
    "description_pattern": "{{businessName}} provides professional {{serviceType}} contracting services in {{city}}, {{state}}. Request a free estimate today.",
    "schema_type": "HomeAndConstructionBusiness",
    "og_image_pattern": "{{businessName}} — Quality Craftsmanship",
    "keywords": ["contractor", "construction", "remodeling", "home improvement", "renovation"]
  },

  "feature_flags": {
    "enable_intake_form": false,
    "enable_chat_widget": false,
    "enable_blog": false,
    "enable_case_results": false,
    "enable_video_hero": false,
    "safe_mode": true
  }
}
