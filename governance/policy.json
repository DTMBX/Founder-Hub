{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "lastUpdated": "2026-02-17",
  "organization": "Founder-Hub",
  
  "branchProtection": {
    "main": {
      "requirePullRequest": true,
      "requiredReviewers": 1,
      "dismissStaleReviews": true,
      "requireCodeOwnerReview": true,
      "requireStatusChecks": true,
      "requiredChecks": [
        "build",
        "test",
        "lint",
        "security-scan"
      ],
      "requireLinearHistory": true,
      "allowForcePush": false,
      "allowDeletion": false,
      "enforceAdmins": true
    },
    "staging": {
      "requirePullRequest": true,
      "requiredReviewers": 1,
      "requireStatusChecks": true,
      "requiredChecks": ["build", "test"],
      "allowForcePush": false
    },
    "develop": {
      "requirePullRequest": false,
      "requireStatusChecks": true,
      "requiredChecks": ["build", "test"],
      "allowForcePush": false
    }
  },
  
  "deploymentGates": {
    "preview": {
      "requiredChecks": ["build", "test"],
      "autoDeploy": true,
      "requireApproval": false,
      "notifyChannels": ["#deploys"]
    },
    "staging": {
      "requiredChecks": ["build", "test", "lint", "security-scan"],
      "autoDeployFromBranch": "staging",
      "requireApproval": false,
      "notifyChannels": ["#deploys", "#staging"]
    },
    "production": {
      "requiredChecks": ["build", "test", "lint", "security-scan", "e2e"],
      "autoDeployFromBranch": null,
      "requireApproval": true,
      "requiredApprovers": ["@DTMBX/admins"],
      "deploymentWindow": {
        "allowedDays": ["Monday", "Tuesday", "Wednesday", "Thursday"],
        "allowedHours": {"start": "09:00", "end": "16:00"},
        "timezone": "America/New_York"
      },
      "notifyChannels": ["#deploys", "#production"],
      "rollbackPlan": "required"
    }
  },
  
  "secretManagement": {
    "scanner": "enabled",
    "pushProtection": true,
    "alertRecipients": ["security@devon-tyler.com"],
    "forbiddenPatterns": [
      "AWS_ACCESS_KEY",
      "AWS_SECRET_KEY",
      "GITHUB_TOKEN",
      "STRIPE_SECRET",
      "DATABASE_URL",
      "PRIVATE_KEY"
    ],
    "allowedSecretSources": [
      "GitHub Secrets",
      "Netlify Environment"
    ]
  },
  
  "codeReview": {
    "requireApproval": true,
    "minimumReviewers": 1,
    "codeOwnersMandatory": true,
    "autoAssignReviewers": true,
    "reviewerGroups": {
      "frontend": ["@DTMBX/frontend"],
      "backend": ["@DTMBX/backend"],
      "security": ["@DTMBX/security"],
      "infrastructure": ["@DTMBX/devops"]
    }
  },
  
  "dependencyManagement": {
    "dependabot": {
      "enabled": true,
      "schedule": "weekly",
      "autoMerge": {
        "minorUpdates": true,
        "patchUpdates": true,
        "majorUpdates": false
      },
      "securityUpdates": {
        "autoMerge": true,
        "prioritize": true
      }
    },
    "allowedLicenses": [
      "MIT",
      "Apache-2.0",
      "BSD-2-Clause",
      "BSD-3-Clause",
      "ISC",
      "0BSD"
    ],
    "blockedPackages": []
  },
  
  "backup": {
    "schedule": "0 2 * * *",
    "retention": {
      "daily": 7,
      "weekly": 4,
      "monthly": 12
    },
    "destinations": [
      {
        "type": "mirror",
        "provider": "github",
        "repository": "DTMBX/Founder-Hub-mirror"
      }
    ],
    "verifyAfterBackup": true
  },
  
  "incidentResponse": {
    "rollbackTimeTarget": "15m",
    "escalationPath": [
      {"level": 1, "contact": "on-call-engineer", "timeout": "5m"},
      {"level": 2, "contact": "@DTMBX/admins", "timeout": "15m"},
      {"level": 3, "contact": "security@devon-tyler.com", "timeout": "30m"}
    ],
    "communicationChannels": ["#incidents", "#production"],
    "postMortemRequired": true
  },
  
  "compliance": {
    "dataClassification": "required",
    "auditLogging": "enabled",
    "retentionPeriod": "7y",
    "accessReview": "quarterly"
  }
}
