{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EscrowManifest",
  "description": "B13-P4 — Schema for artifact escrow manifests.",
  "type": "object",
  "required": ["version", "records", "lastUpdated"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EscrowRecord"
      }
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "EscrowRecord": {
      "type": "object",
      "required": [
        "escrowId",
        "artifactPath",
        "sha256",
        "sizeBytes",
        "repo",
        "commitHash",
        "createdAt",
        "createdBy",
        "status"
      ],
      "properties": {
        "escrowId": {
          "type": "string",
          "pattern": "^escrow_"
        },
        "artifactPath": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "repo": {
          "type": "string"
        },
        "commitHash": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdBy": {
          "type": "string"
        },
        "expiresAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["held", "released", "expired"]
        },
        "releaseJustification": {
          "type": ["string", "null"]
        },
        "releasedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "releasedBy": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
