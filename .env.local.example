# ============================================================================
# LOCAL DEVELOPMENT CREDENTIALS
# ============================================================================
# Copy this file to .env.local — it is gitignored and NEVER committed.
# .env.local is loaded by Vite automatically in dev mode (npm run dev).
#
# On GitHub/live: set these as GitHub Actions Secrets instead (see below).
# ============================================================================

# ─── OPTION A: Legacy localStorage auth (simplest) ──────────────────────────
# These credentials are used to bootstrap the admin account in localStorage
# on first page load. Change to your real email/password.
VITE_ADMIN_EMAIL=your@email.com
VITE_ADMIN_PASSWORD=YourStrongPassword123!

# ─── OPTION B: Supabase auth (recommended for live) ─────────────────────────
# When these are set, legacy auth is ignored entirely.
# Get from: https://supabase.com → your project → Settings → API
# These are PUBLIC values (anon key is safe to use client-side).
#VITE_SUPABASE_URL=https://your-project-id.supabase.co
#VITE_SUPABASE_ANON_KEY=your-anon-key-here
